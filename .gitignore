# Claude
.claude/
.codex

# Environment / secrets (never commit)
.env
.env.local
.env.*

# Outputs
outputs/
!outputs/
outputs/*
!outputs/generated_state.json

# Kitchen image downloads (keep scripts, ignore binaries)
generator/kitchen_img/*.jpg
generator/kitchen_img/*.jpeg
generator/kitchen_img/*.png
generator/kitchen_img/*.webp
generator/kitchen_img/*.bmp
generator/kitchen_img/*.tif
generator/kitchen_img/*.tiff
generator/kitchen_img/download_state.json
generator/kitchen_img/.curator_cache/

# Local curated/generated 3D assets (never track binaries)
generator/models/**
!generator/models/**/
!generator/models/**/.gitkeep

# Model checkpoints / weights (large binaries)
model.ckpt
*.ckpt
*.pt
*.pth
*.bin
*.safetensors
*.onnx

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Blender
*.blend1
*.blend2

# TripoSR clone (created by setup scripts)
.triposr_clone/

# HuggingFace dataset repo (managed by its own git remote)
pest_detection_dataset/

# Trained model checkpoints
pest_detection_model/
pest_detection_model2/
